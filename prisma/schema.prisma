generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMINISTRADOR
  GERENTE
  EMPLEADO
}

enum TaskStatus {
  PENDIENTE
  EN_PROCESO
  PENDIENTE_APROBACION
  COMPLETADA
}

enum NotificationType {
  KPI_RIESGO
  TAREA_VENCIDA
  OBJETIVO_PROXIMO
  WORKFLOW_PENDIENTE
  SISTEMA
}

enum WorkflowType {
  TAREA_COMPLETADA
  KPI_AJUSTE
}

enum WorkflowStatus {
  PENDIENTE
  APROBADA
  RECHAZADA
  CANCELADA
}

enum AsistenciaTipo {
  PRESENTE
  IMPUNTUALIDAD
  INASISTENCIA_INJUSTIFICADA
  VACACIONES
  LICENCIA_EXAMEN
  LICENCIA_MUDANZA
  LICENCIA_GREMIAL
  LICENCIA_NACIMIENTO
  LICENCIA_FALLECIMIENTO
  CARPETA_MEDICA_JUSTIFICADA
  ACCIDENTE_TRABAJO
  SANCION_DISCIPLINARIA
  SUSPENSION_DISCIPLINARIA
  OTRO_JUSTIFICADO
}

enum MetaColectivaTipo {
  RECLAMOS
  VENTAS
  COBRANZAS
}

enum EvaluacionRol {
  AUTOEVALUACION
  GERENTE
  PAR
  SUBORDINADO
}

enum ScoreAuditEvento {
  CALCULO_AUTOMATICO
  RECALCULO_MANUAL
  IMPORTACION_ASISTENCIA
  AJUSTE_ADMIN
  CIERRE_SEMESTRE
}

enum ImportBatchTipo {
  EMPLEADOS
  ASISTENCIA
}

model Organization {
  id                  String                  @id @default(cuid())
  slug                String                  @unique
  name                String
  tagline             String?
  logoUrl             String?
  primaryColor        String?
  activo              Boolean                 @default(true)
  /** Si false, no se muestra ni calcula premio a la productividad */
  premioHabilitado    Boolean                 @default(true)
  areas               Area[]
  users               User[]
  configs             SystemConfig[]
  metasColectivas     MetaColectivaSemestre[]
  ciclosEvaluacion    Evaluacion360Ciclo[]
  kpiSnapshots        KpiSnapshot[]
  apiKeys             OrganizationApiKey[]
  createdAt           DateTime                @default(now())
  updatedAt           DateTime                @updatedAt
}

model OrganizationApiKey {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name           String
  keyPrefix      String
  keyHash        String
  scopes         String[]
  activo         Boolean      @default(true)
  lastUsedAt     DateTime?
  expiresAt      DateTime?
  createdById    String?
  createdAt      DateTime     @default(now())

  @@index([organizationId, activo])
  @@index([keyPrefix])
}

model Area {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  nombre         String
  usuarios       User[]
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([organizationId, nombre])
  @@index([organizationId])
}

model User {
  id                  String                   @id @default(cuid())
  organizationId      String
  organization        Organization             @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  email               String
  password            String
  nombre              String
  apellido            String
  role                Role                     @default(EMPLEADO)
  legajo              String?
  externalId          String?
  telefono            String?
  activo              Boolean                  @default(true)
  fechaAlta           DateTime                 @default(now())
  fechaBaja           DateTime?
  sueldoBasico        Float?
  valorAntiguedad     Float?
  areaId              String
  area                Area                     @relation(fields: [areaId], references: [id])
  objetivos           Objetivo[]
  tareas              Tarea[]
  notifications       Notification[]
  passwordResetTokens PasswordResetToken[]
  asistencias         AsistenciaRegistro[]
  evaluacionesRecibidas Evaluacion360Respuesta[] @relation("Evaluado")
  evaluacionesEnviadas  Evaluacion360Respuesta[] @relation("Evaluador")
  scoreAudits         ScoreAuditLog[]
  importBatches       ImportBatch[]
  kpiSnapshots        KpiSnapshot[]
  workflowsSolicitados WorkflowRequest[] @relation("WorkflowSolicitante")
  workflowsResueltos   WorkflowRequest[] @relation("WorkflowResolutor")
  createdAt           DateTime                 @default(now())
  updatedAt           DateTime                 @updatedAt

  @@unique([organizationId, email])
  @@unique([organizationId, legajo])
  @@unique([organizationId, externalId])
  @@index([activo, areaId])
  @@index([organizationId])
}

model MetaColectivaSemestre {
  id             String            @id @default(cuid())
  organizationId String
  organization   Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  periodoId      String
  tipo           MetaColectivaTipo
  valorMeta      Float
  valorActual    Float             @default(0)
  observacion    String?
  updatedAt      DateTime          @updatedAt
  createdAt      DateTime          @default(now())

  @@unique([organizationId, periodoId, tipo])
}

model Objetivo {
  id          String   @id @default(cuid())
  titulo      String
  descripcion String?
  fechaInicio DateTime
  fechaFin    DateTime
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  kpis        KPI[]
  tareas      Tarea[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model KPI {
  id          String        @id @default(cuid())
  nombre      String
  valorMeta   Float
  valorActual Float         @default(0)
  unidad      String
  objetivoId  String
  objetivo    Objetivo      @relation(fields: [objetivoId], references: [id], onDelete: Cascade)
  snapshots   KpiSnapshot[]
  workflows   WorkflowRequest[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

model KpiSnapshot {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  kpiId          String
  kpi            KPI          @relation(fields: [kpiId], references: [id], onDelete: Cascade)
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  periodoId      String
  valorActual    Float
  valorMeta      Float
  cumplimiento   Float
  capturedAt     DateTime     @default(now())

  @@index([kpiId, periodoId])
  @@index([userId, periodoId])
  @@index([organizationId, periodoId])
}

model Tarea {
  id                  String     @id @default(cuid())
  titulo              String
  descripcion         String?
  estado              TaskStatus @default(PENDIENTE)
  tiempoEstimado      Int
  tiempoReal          Int?
  prioridad           Int        @default(2)
  fechaLimite         DateTime?
  startedAt           DateTime?
  completedAt         DateTime?
  assignedAt          DateTime   @default(now())
  evaluaProductividad Boolean    @default(true)
  pesoProductividad   Int        @default(1)
  userId              String
  user                User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  objetivoId          String?
  objetivo            Objetivo?  @relation(fields: [objetivoId], references: [id], onDelete: SetNull)
  workflows           WorkflowRequest[]
  createdAt           DateTime   @default(now())
  updatedAt           DateTime   @updatedAt
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  tipo      NotificationType
  titulo    String
  mensaje   String
  leida     Boolean          @default(false)
  metadata  Json?
  createdAt DateTime         @default(now())

  @@index([userId, leida])
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
}

model LoginAttempt {
  id        String   @id @default(cuid())
  email     String
  success   Boolean
  ipAddress String?
  createdAt DateTime @default(now())

  @@index([email, createdAt])
}

model SystemConfig {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  clave          String
  valor          Json
  descripcion    String?
  updatedAt      DateTime     @updatedAt
  updatedById    String?

  @@unique([organizationId, clave])
}

model ImportBatch {
  id          String               @id @default(cuid())
  tipo        ImportBatchTipo
  archivo     String
  filasTotal  Int
  filasOk     Int
  filasError  Int
  errores     Json?
  subidoPorId String
  subidoPor   User                 @relation(fields: [subidoPorId], references: [id])
  asistencias AsistenciaRegistro[]
  createdAt   DateTime             @default(now())
}

model AsistenciaRegistro {
  id            String         @id @default(cuid())
  userId        String
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  fecha         DateTime       @db.Date
  tipo          AsistenciaTipo
  minutosTarde  Int?
  observacion   String?
  periodoId     String
  importBatchId String?
  importBatch   ImportBatch?   @relation(fields: [importBatchId], references: [id], onDelete: SetNull)
  creadoPorId   String?
  createdAt     DateTime       @default(now())

  @@unique([userId, fecha])
  @@index([userId, periodoId])
}

model ScoreAuditLog {
  id             String           @id @default(cuid())
  userId         String
  user           User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  periodoId      String
  evento         ScoreAuditEvento
  puntajeBase    Float
  inasistencias  Int
  multiplicador  Float
  puntajeFinal   Float
  detalle        Json
  realizadoPorId String?
  createdAt      DateTime         @default(now())

  @@index([userId, periodoId])
}

model Evaluacion360Ciclo {
  id             String                   @id @default(cuid())
  organizationId String
  organization   Organization             @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  titulo         String
  periodoId      String
  fechaInicio    DateTime
  fechaFin       DateTime
  activo         Boolean                  @default(true)
  respuestas     Evaluacion360Respuesta[]
  createdAt      DateTime                 @default(now())
  updatedAt      DateTime                 @updatedAt

  @@index([organizationId, activo])
}

model Evaluacion360Respuesta {
  id          String             @id @default(cuid())
  cicloId     String
  ciclo       Evaluacion360Ciclo @relation(fields: [cicloId], references: [id], onDelete: Cascade)
  evaluadoId  String
  evaluado    User               @relation("Evaluado", fields: [evaluadoId], references: [id], onDelete: Cascade)
  evaluadorId String
  evaluador   User               @relation("Evaluador", fields: [evaluadorId], references: [id], onDelete: Cascade)
  rol         EvaluacionRol
  competencia String
  puntaje     Int
  comentario  String?
  createdAt   DateTime           @default(now())

  @@unique([cicloId, evaluadoId, evaluadorId, competencia])
}

model WorkflowRequest {
  id                   String         @id @default(cuid())
  organizationId       String
  tipo                 WorkflowType
  estado               WorkflowStatus @default(PENDIENTE)
  solicitanteId        String
  solicitante          User           @relation("WorkflowSolicitante", fields: [solicitanteId], references: [id], onDelete: Cascade)
  resolutorId          String?
  resolutor            User?          @relation("WorkflowResolutor", fields: [resolutorId], references: [id], onDelete: SetNull)
  tareaId              String?
  tarea                Tarea?         @relation(fields: [tareaId], references: [id], onDelete: Cascade)
  kpiId                String?
  kpi                  KPI?           @relation(fields: [kpiId], references: [id], onDelete: Cascade)
  valorAnterior        Float?
  valorPropuesto       Float?
  comentarioSolicitud  String?
  comentarioResolucion String?
  resolvedAt           DateTime?
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt

  @@index([organizationId, estado])
  @@index([solicitanteId, estado])
  @@index([tareaId])
  @@index([kpiId])
}
