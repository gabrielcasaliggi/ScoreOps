# PostgreSQL local — credenciales creadas por scripts/setup-postgres.sh
DATABASE_URL="postgresql://vertia:vertia_local_2026@localhost:5432/gestion_tareas?schema=public"

# Secreto para sesiones (generar uno seguro en producción)
SESSION_SECRET="cambiar-por-secreto-seguro-en-produccion"

# Entorno
NODE_ENV="development"

# URL pública de la app (define si la cookie de sesión es Secure)
# Ej. http://181.41.240.16  o  https://scoreops.cooperativa.local
APP_URL="http://localhost:3000"

# Forzar cookie Secure (opcional; si no se define, se infiere de APP_URL)
# SESSION_COOKIE_SECURE="false"

# Clave legacy para integración RRHH (opcional; preferir API keys por org en Configuración)
INTEGRATION_API_KEY=""

# IA local opcional (Ollama) para resumen semanal del empleado
# OLLAMA_BASE_URL="http://localhost:11434"
# OLLAMA_MODEL="llama3.2"

# Organización por defecto (multi-tenant)
DEFAULT_ORG_SLUG="demo"
DEFAULT_ORG_NAME="Cooperativa Demo"

# Emails con acceso super-admin Vertia (NO incluir usuarios de demo comercial)
VERTIA_SUPER_ADMIN_EMAILS="soporte@vertia.local"

# --- Observabilidad (opcional) ---
# Versión desplegada (útil en logs y /api/health)
APP_VERSION="0.1.0"

# Sentry — errores centralizados (https://sentry.io). Sin DSN, solo logs JSON en stdout.
# SENTRY_DSN=""
# SENTRY_ENVIRONMENT="production"
# SENTRY_TRACES_SAMPLE_RATE="0.1"

# Token para health detallado (?detailed=1). UptimeRobot/cron: scripts/check-health.sh
# HEALTH_CHECK_TOKEN=""

# Nivel de log: debug | info (default implícito)
# LOG_LEVEL="info"
